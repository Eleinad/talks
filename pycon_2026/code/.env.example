# Copy this file to .env and fill in your values

# Path to your images directory (required)
DEFAULT_IMAGES_DIR=C:/Users/yourname/Pictures

# CLIP model (default: clip-ViT-B-32)
CLIP_MODEL_NAME=clip-ViT-B-32
CLIP_CACHE_DIR=./clip_model

# FastAPI backend URL (default: http://localhost:8000)
API_URL=http://localhost:8000

# Streamlit origin for CORS (default: http://localhost:8501)
STREAMLIT_ORIGIN=http://localhost:8501

# Root folders for persisted data
FAISS_ROOT=./faiss
BERTOPIC_ROOT=./bertTopic

# Optuna trials (lower for faster iteration, higher for better clustering)
OPTUNA_N_TRIALS=500
OPTUNA_TIMEOUT=300
